function TBank.Hover(walkerObject: PWalkerObject = nil): Boolean; overload;
begin
  if walkerObject = nil then
    walkerObject := WalkerObjects.Banks.GetClosest();

  if walkerObject^.Filter.MinimapDot then
    Exit(Self.Hover(PGameNPC(walkerObject)^));

  Result := Bank.Hover(PGameObject(walkerObject)^);
end;

function TBank.Open(walkerObject: PWalkerObject = nil): Boolean; overload;
begin
  if walkerObject = nil then
    walkerObject := WalkerObjects.Banks.GetClosest();

  if walkerObject^.Filter.MinimapDot then
    Exit(Bank.Open(PGameNPC(walkerObject)^));

  Result := Bank.Open(PGameObject(walkerObject)^);
end;

