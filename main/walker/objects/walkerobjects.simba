```
*)
function TMMDot.WalkSelectOption(action: TStringArray; attempts: Int32 = 2): Boolean;
begin
  Self.ActionUpText := action;
  Self.CurrentActionUpText := action;
  Result := Self.WalkHover(attempts) and Self._SelectHelper(action);
  Self.ActionUpText := [];
  Self.CurrentActionUpText := [];
end;

type
(*
## type TNPC
TNPC are a type of TMMDot and TWalkerObject.
This are meant to be TMMDot that have a yellow minimap dot so TNPC.Filter.MinimapDot is True by default and shouldn't be changed.
*)
  TNPC = type TMMDot;
  TNPCArray = array of TNPC;
  PGameNPC = ^TNPC;
  PGameNPCArray = array of PGameNPC;

(*
## type TGroundItem
TGroundItem are a type of TMMDot and TWalkerObject.
This are meant to be TMMDot that have a red minimap dot so TGroundItem.Filter.MinimapDot is True by default and shouldn't be changed.
*)
  TGroundItem = type TMMDot;
  TGroundItemArray = array of TGroundItem;
  PRSGroundItem = ^TGroundItem;
  PRSGroundItemArray = array of PRSGroundItem;

(*
## type TPlayer

TPlayer are a type of TMMDot and TWalkerObject.
This are meant to be TMMDot that have a white minimap dot so TPlayer.Filter.MinimapDot is True by default and shouldn't be changed.
*)
  TPlayer = type TMMDot;
  TPlayerArray = array of TPlayer;

(*
## TMMDot.SetupUpText
```pascal
procedure TNPC.SetupUpText(upText: TStringArray); override;
procedure TGroundItem.SetupUpText(upText: TStringArray); override;
procedure TPlayer.SetupUpText(upText: TStringArray); override;
```
Setup method that extends TWalkerObject.SetupUpText(upText: TStringArray);
These are the methods that should be used to setup TNPCs, TGroundItems and TPlayers as it ensures that the
TNPC.DotType is correctly set.
*)
procedure TNPC.Setup(upText: TStringArray); override; //deprecated 'Use TNPC.SetupUpText() instead.';
begin
  WriteLn('TNPC.Setup() is deprecated use TNPC.SetupUpText() instead.');
  if Self.Filter.Skip then
    Exit;

  Self._Setup();
  Self.Filter.MinimapDot := True;

  Self.UpText := upText;

  Self.Finder.ClusterDistance := 3;
  Self.Finder.Erode := 2;
  Self.Finder.Grow := 4;
  Self.DotType := EMinimapDot.NPC;
end;

procedure TNPC.SetupUpText(upText: TStringArray); override;
begin
  if Self.Filter.Skip then
    Exit;

  Self._Setup();
  Self.Filter.MinimapDot := True;

  Self.UpText := upText;

  Self.Finder.ClusterDistance := 3;
  Self.Finder.Erode := 2;
  Self.Finder.Grow := 4;
  Self.DotType := EMinimapDot.NPC;
end;

procedure TGroundItem.SetupUpText(upText: TStringArray); override;
begin
  if Self.Filter.Skip then
    Exit;

  Self._Setup();
  Self.Filter.MinimapDot := True;

  Self.UpText := upText;

  Self.Finder.ClusterDistance := 3;
  Self.Finder.Erode := 2;
  Self.Finder.Grow := 4;
  Self.DotType := EMinimapDot.ITEM;
end;

procedure TPlayer.SetupUpText(upText: TStringArray); override;
begin
  if Self.Filter.Skip then
    Exit;

  Self._Setup();
  Self.Filter.MinimapDot := True;

  Self.UpText := upText;

  Self.Finder.ClusterDistance := 3;
  Self.Finder.Erode := 2;
  Self.Finder.Grow := 4;
  Self.DotType := EMinimapDot.PLAYER;
end;


function PGameNPCArray.GetClosestEx(value: TPoint): PGameNPC;
var
  i: Int32;
  closest, current: Double;
begin
  if Self = [] then
    Exit;

  closest := $FFFFFF;

  for i := High(Self) downto 0 do
  begin
    if Self[i]^.Coordinates = [] then
    begin
      Delete(Self, i, 1);
      Continue;
    end;

    current := Self[i]^.Coordinates.NearestPoint(value).DistanceTo(value);
    if current < closest then
    begin
      closest := current;
      Result := Self[i];
    end;
  end;
end;

function PGameNPCArray.GetClosest(): PGameNPC;
begin
  if (Self = []) or (ScriptWalker = nil) then
    Exit;

  Result := Self.GetClosestEx(ScriptWalker^.GetMyPos());
end;


function PRSGroundItemArray.GetClosestEx(value: TPoint): PRSGroundItem;
var
  i: Int32;
  closest, current: Double;
begin
  if Self = [] then
    Exit;

  closest := $FFFFFF;

  for i := High(Self) downto 0 do
  begin
    if Self[i]^.Coordinates = [] then
    begin
      Delete(Self, i, 1);
      Continue;
    end;

    current := Self[i]^.Coordinates.NearestPoint(value).DistanceTo(value);
    if current < closest then
    begin
      closest := current;
      Result := Self[i];
    end;
  end;
end;

function PRSGroundItemArray.GetClosest(): PRSGroundItem;
begin
  if (Self = []) or (ScriptWalker = nil) then
    Exit;

  Result := Self.GetClosestEx(ScriptWalker^.GetMyPos());
end;


(*
## Debug
```pascal
procedure Debug(GameObject: TGameObject); overload;
procedure Debug(mmdot: TMMDot); overload;
```
Methods used to debug TGameObjects and TMMDots.

Example:
```pascal
Debug(GameObjects.GEBank); //Run in ge with a walker map setup there.

Debug(RSNPCs.LumbridgeCook); //Run in Lumbridge castle with a walker map setup there.
```
*)
procedure Debug(GameObject: TGameObject); overload;
var
  bitmap: TMufasaBitmap;
begin
  bitmap.FromClient();
  GameObject.Draw(bitmap);
  bitmap.Debug();
  bitmap.Free();
end;

procedure Debug(mmdot: TMMDot); overload;
var
  bitmap: TMufasaBitmap;
begin
  bitmap.FromClient();
  mmDot.Draw(bitmap);
  bitmap.Debug();
  bitmap.Free();
end;

type
  TWalkerObjects = record
    Banks, DepositBoxes: PWalkerObjectArray;
  end;

var
  WalkerObjects: TWalkerObjects;
  DebugObjectArray: TGameObjectArray;
  DebugMMDotArray: array of TMMDot;

function TBank.Hover(GameObject: TGameObject): Boolean; overload;
begin
  if GameInterface.IsOpen() then Exit;
  Result := GameObject.Hover();
end;

function TBank.Open(GameObject: TGameObject): Boolean; overload;
begin
  if GameInterface.IsOpen() then
  begin
    if Self.IsOpen() or BankPin.IsOpen() then
      Exit(True);
    GameInterface.Close();
  end;

  Result := GameObject.Click() or (MainScreen.IsUpText('Banker') and ChooseOption.Select(['Bank B', 'Bank E']));

  if not Result then Exit;

  Minimap.WaitMoving();
  Result := WaitUntil(Self.IsOpen() or BankPin.IsOpen(), SRL.TruncatedGauss(50, 1500), 3000);
end;

function TBank.WalkHover(GameObject: TGameObject): Boolean;
begin
  if GameInterface.IsOpen() then Exit;

  Result := GameObject.WalkHover();
end;

function TBank.WalkOpen(GameObject: TGameObject): Boolean;
begin
  if GameInterface.IsOpen() then
  begin
    if Self.IsOpen() or BankPin.IsOpen() then
      Exit(True);
    GameInterface.Close();
  end;

  Result := GameObject.WalkClick() or (MainScreen.IsUpText('Banker') and ChooseOption.Select(['Bank B', 'Bank E']));

  if not Result then Exit;

  Minimap.WaitMoving();
  Result := WaitUntil(Self.IsOpen(), SRL.TruncatedGauss(50, 1500), 3000);
end;


