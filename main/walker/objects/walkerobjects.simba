procedure TSRL.Debug(Bitmap: TMufasaBitmap); override;
var
  DebugObject: TGameObject;
  DebugDot: TMMDot;
begin
  inherited;

  for DebugObject in DebugObjectArray do
    DebugObject.Draw(Bitmap);

  for DebugDot in DebugMMDotArray do
    DebugDot.Draw(Bitmap);
end;
