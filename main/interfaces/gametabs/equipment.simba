{$DEFINE WL_EQUIPMENT_INCLUDED}
{$IFNDEF WL_MAIN}
  {$I WaspLib/main.simba}
{$ENDIF}

function TEquipment.FindItems(items: TItemArray; out slots: TIntegerArray): Boolean; override;
var
  item: TItem;
  tmp: TItemArray;
begin
  if not Self.Open() then Exit;

  for item in items do tmp += item.GetArray();

  slots := Self.Items.IndicesOf(tmp);
  Result := Length(slots) > 0;
end;
